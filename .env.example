# Groq API key — get a free one at https://console.groq.com
GROQ_API_KEY=your_key_here

# Optional: override the Groq model (defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Which wearable to read from: "auto" (default — Whoop if connected, else Google
# Fit, else synthetic), "whoop", or "google_fit".
# WEARABLE_SOURCE=auto

# Whoop OAuth — register an app at https://developer.whoop.com
# WHOOP_CLIENT_ID=your_whoop_client_id
# WHOOP_CLIENT_SECRET=your_whoop_client_secret
# WHOOP_REDIRECT_URI=http://localhost:8000/auth/whoop/callback

# Optional: base URL the standalone Gradio frontend uses to reach the FastAPI
# backend. Leave unset when the UI is mounted inside FastAPI (Docker / HF Spaces).
# BACKEND_URL=http://localhost:8000

# Optional: Google OAuth redirect URI registered in your Google Cloud credentials.
# OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
