# Groq API key — get a free one at https://console.groq.com
GROQ_API_KEY=your_key_here

# Optional: override the Groq model (defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: base URL the standalone Gradio frontend uses to reach the FastAPI
# backend. Leave unset when the UI is mounted inside FastAPI (Docker / HF Spaces).
# BACKEND_URL=http://localhost:8000

# Optional: OAuth redirect URI registered in your Google Cloud credentials.
# OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
